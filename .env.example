# ── compose 인프라 ──────────────────────────────────────────
POSTGRES_USER=axkg
POSTGRES_PASSWORD=axkg
POSTGRES_DB=axkg

# Markdown SoT root (호스트 경로) — 운영은 knowledge workspace 경로 지정
AXKG_WORKSPACE_HOST_PATH=./data/documents

# ── api (axkg 런타임) ───────────────────────────────────────
AXKG_DATABASE_URL=postgresql+psycopg://axkg:axkg@postgres:5432/axkg
AXKG_MARKDOWN_ROOT=/workspace
AXKG_REDIS_URL=redis://redis:6379
AXKG_OPEN_KKNAKS_BASE_URL=
AXKG_AUTH_TOKEN_TTL_DAYS=30
AXKG_DEFAULT_PROVIDER=claude
AXKG_SLACK_SIGNING_SECRET=
AXKG_CORS_ORIGINS=http://localhost:3000,http://localhost:43000
AXKG_SLACK_BOT_TOKEN=

# ── open-kknaks worker ──────────────────────────────────────
REDIS_URL=redis://redis:6379
NAMESPACE=axkg
QUEUES=default
CONCURRENCY=2
WORK_DIR=/tmp
CLAUDE_CODE_OAUTH_TOKEN=
# claude CLI가 설치된 호스트 홈 (mac: /Users/kknaks/.local, 서버: /home/kknaks/.local)
CLAUDE_LOCAL_DIR=/home/kknaks/.local

# ── web ─────────────────────────────────────────────────────
NEXT_PUBLIC_AXKG_API_BASE_URL=http://localhost:48100
