# API base URL (api-client가 브라우저에서 사용)
# - http://localhost:48100 : compose api 직접 호출 (API가 CORS 허용)
# - http://localhost:8000  : 로컬 uvicorn 직접 호출
# - /backend               : next.config.ts rewrites same-origin 프록시 (CORS 불가 환경용)
NEXT_PUBLIC_AXKG_API_BASE_URL=http://localhost:48100

# /backend 프록시 사용 시 실제 API 주소 (server-side only)
# AXKG_API_PROXY_TARGET=http://localhost:48100
